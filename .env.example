# ---- Backend selector ----
EXPO_PUBLIC_BACKEND=local            # 'local' (on-device) | 'supabase' (nube)

# ---- Supabase ----
# Panel: Project Settings → API. Formato de claves NUEVO (sb_publishable_ / sb_secret_).
EXPO_PUBLIC_SUPABASE_URL=            # https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=       # sb_publishable_...  (client-safe; la RLS protege)
SUPABASE_URL=                        # igual que arriba, para scripts de servidor
SUPABASE_SERVICE_ROLE_KEY=           # sb_secret_...  server-only: importer/push

# ---- Metadata (TMDB) ----
TMDB_ACCESS_TOKEN=                   # v4 read token (preferido)
# TMDB_API_KEY=                      # o una v3 key

# ---- Steam ("Iniciar sesión con Steam") ----
# La API key de Steam ya NO va en el cliente: vive como secreto de la Edge Function
# `steam-auth`. Configúralos UNA vez (no en este .env) con:
#   supabase secrets set STEAM_WEB_API_KEY=xxxx STEAM_AUTH_SECRET=$(openssl rand -hex 32)
#   STEAM_WEB_API_KEY   -> https://steamcommunity.com/dev/apikey
#   STEAM_AUTH_SECRET   -> cadena aleatoria; firma el SteamID (HMAC) entre login y fetch
#   STEAM_ALLOWED_HOSTS -> (opcional) hosts web permitidos como redirect, ej. gamerhoard.pages.dev
