# Public config for the mobile/web client (safe to expose; RLS protects data).

# Backend: 'local' (on-device SQLite, default) | 'supabase' (cloud)
EXPO_PUBLIC_BACKEND=local

# RAWG API key: get a free one at https://rawg.io/apidocs
EXPO_PUBLIC_RAWG_KEY=

# Steam (optional): you can also paste the key in the import screen.
# Get one at https://steamcommunity.com/dev/apikey
EXPO_PUBLIC_STEAM_KEY=
# WEB only: CORS proxy for Steam calls (receives the encoded target URL).
EXPO_PUBLIC_STEAM_PROXY=

# Only needed when EXPO_PUBLIC_BACKEND=supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
